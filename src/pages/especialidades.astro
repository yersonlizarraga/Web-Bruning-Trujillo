---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Especialidades | BRÜNING TRUJILLO" description="Descubre los talleres artísticos y deportivos de Brüning School. Música, danza, fútbol, básquet y más actividades extracurriculares para el desarrollo integral de tus hijos.">
  <main class="pt-24 md:pt-20">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-colegio-blue via-colegio-blue/90 to-colegio-blue text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
          Nuestras <span class="text-colegio-yellow">Especialidades Artísticas</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto">
          Espacios de formación integral que complementan la excelencia académica y potencian las habilidades de nuestros estudiantes
        </p>
      </div>
    </section>

    <!-- Filtros de categoría -->
    <section class="py-10 bg-white sticky top-16 z-40 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-3">
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="primaria">🎵💃PRIMARIA🎨</button>
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="secundaria">🎵💃SECUNDARIA🎨🎭</button>
      </div>
    </section>

    <!-- ── PRIMARIA ── -->
    <section data-talleres-section="primaria" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Especailidades Artísticas Primaria</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Espacios de expresión creativa donde nuestros estudiantes descubren y desarrollan su talento artístico, cultivando la sensibilidad, la creatividad y el amor por el arte.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Danza -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/danza.jpg" alt="Taller de Danza"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1508700929628-666bc8bd84ea?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">💃Danza</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Aprendizaje de danzas peruanas que fortalecen la identidad cultural y la expresión corporal.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Danzas de costa, sierra y selva</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Coordinación motriz y expresión corporal</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Presentaciones en actividades culturales</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Música -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎵Música</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Formación musical mediante la práctica instrumental y vocal, fomentando el ritmo, la creatividad y el trabajo en equipo.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Cajón, ukelele, flauta y xilófono melódico</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Desarrollo del ritmo y coordinación musical</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Participaciones artísticas y coro escolar</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/musica.jpg" alt="Taller de Música"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Dibujo y Pintura -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/dibujo.jpg" alt="Taller de Dibujo y Pintura"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎨Dibujo y Pintura</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                 Espacio de creatividad donde los estudiantes exploran diversas técnicas de arte y expresión visual.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Creatividad y la imaginación</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Modelado, arte vitral y técnicas creativas</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Creación de trabajos artísticos</span>
                </li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── SECUNDARIA ── -->
    <section data-talleres-section="secundaria" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Especailidades Artísticas Secundaria</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Espacios de expresión creativa donde nuestros estudiantes descubren y desarrollan su talento artístico, cultivando la sensibilidad, la creatividad y el amor por el arte.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Danza -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/danza.jpg" alt="Taller de Danza"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1508700929628-666bc8bd84ea?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">💃Danza</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Profundización en danzas tradicionales del Perú como expresión artística y cultural.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Danzas de costa, sierra y selva</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Expresión corporal y presencia escénica</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Participación en eventos culturales</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Música -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎵Música</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                 Desarrollo de habilidades musicales a través de la interpretación instrumental y vocal.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Práctica instrumental y técnica vocal</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Desarrollo del ritmo y apreciación musical</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Participaciones artísticas</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/musica.jpg" alt="Taller de Música"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Dibujo y Pintura -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/dibujo.jpg" alt="Taller de Dibujo y Pintura"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1460661419201-fd4cecdf8a8b?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎨Dibujo y Pintura</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                 Desarrollo de proyectos artísticos aplicando diversas técnicas plásticas.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Pintura, arcilla y modelado</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Arte con café y repujado en aluminio</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Creación de proyectos artísticos</span>
                </li>
              </ul>
            </div>
          </div>
        <!-- teatro -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">ARTÍSTICO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎭Teatro</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                 Exploración del arte escénico mediante la actuación y la creación de personajes.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Creación de personajes</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Teatro de objetos y ready-made</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Uso de máscara en escena</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/musica.jpg" alt="Taller de Música"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Beneficios Generales -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Beneficios de Nuestros Talleres</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- Beneficio 1 -->
          <div class="bg-gradient-to-br from-gray-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100">
            <div class="w-16 h-16 bg-gradient-to-br from-colegio-blue to-colegio-blue/80 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-colegio-blue mb-3 text-center">Desarrollo Integral</h3>
