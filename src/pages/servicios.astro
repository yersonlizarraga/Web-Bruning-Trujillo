---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Servicios | BRÜNING TRUJILLO" description="Descubre los talleres artísticos y deportivos de Brüning Trujillo. Música, danza, fútbol, básquet y más actividades extracurriculares para el desarrollo integral de tus hijos.">
  <main class="pt-24 md:pt-20">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-colegio-blue via-colegio-blue/90 to-colegio-blue text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
          Nuestros <span class="text-colegio-yellow">Servicios Complementarios</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto">
          Espacios de formación integral que complementan la excelencia académica y potencian las habilidades de nuestros estudiantes
        </p>
      </div>
    </section>

    <!-- Filtros de categoría -->
    <section class="py-10 bg-white sticky top-16 z-40 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-3">
        <button class="talleres-btn active bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="talleres_extracurriculares">📚 Talleres Extracurriculares</button>
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="elencos">🎼 Elencos</button>
        <button class="talleres-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="taller_deportivo">🏆 Taller Deportivo</button>
      </div>
    </section>

    <!-- ── TALLERES EXTRACURRICULARES ── -->
    <section data-talleres-section="talleres_extracurriculares" class="py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Talleres Extracurriculares</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Actividades opcionales que complementan la formación académica, permitiendo a los 
            estudiantes desarrollar habilidades artísticas, culturales y comunicativas.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Francés -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/frances.jpg" alt="Taller de Francés"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">OPTATIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🗼Francés</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                 Espacio de aprendizaje del idioma francés que permite a los estudiantes desarrollar habilidades básicas de comunicación y conocimiento cultural.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Vacantes: 25 estudiantes</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Nivel 1: 5° y 6° de Primaria</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Nivel 2: 1° y 2° de Secundaria</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Taller de Dibujo y Pintura -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">OPTATIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎨Taller de Dibujo y Pintura</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
               Taller artístico orientado al desarrollo de la creatividad y la expresión visual mediante diversas técnicas plásticas.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Especialidad: Artes Plásticas (Inicial y Primaria)</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Especialidad: Pintura en lienzo (Secundaria)</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/oratorio.jpg" alt="Taller de Oratorio y Declamación"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1475721027785-f74eccf877e2?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Círculo de Excelencia -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/circulo-excelencia.jpg" alt="Círculo de Excelencia"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">OPTATIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎤Taller de Oratoria</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Espacio formativo que fortalece la comunicación, la expresión verbal y no verbal, y la seguridad al hablar en público.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Dirigido a estudiantes de 4° a 6° de Primaria</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Nivel Secundaria</span>
                </li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── ELENCOS ── -->
    <section data-talleres-section="elencos" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Elencos</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Espacios de expresión creativa donde nuestros estudiantes descubren y desarrollan su talento artístico, cultivando la sensibilidad, la creatividad y el amor por el arte.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Elenco de Danzas -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/danza.jpg" alt="Taller de Danza"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1508700929628-666bc8bd84ea?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">EVALUACIÓN DE HABILIDADES</span>
              <h3 class="text-4xl font-bold text-colegio-blue">💃Elenco de Danzas🕺</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Grupo artístico institucional donde los estudiantes desarrollan su talento en la danza y participan en presentaciones culturales.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Evaluación de habilidades</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Participación de estudiantes por nivel de Primaria y Secundaria</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Coro Polifónico -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">EVALUACIÓN DE HABILIDADES</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🎤Coro Polifónico🎶</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Espacio musical que fomenta el desarrollo vocal, el trabajo en equipo y la interpretación coral.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Evaluación de habilidades</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Dirigido a estudiantes de Primaria y Secundaria</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/musica.jpg" alt="Taller de Música"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── TALLER DEPORTIVO ── -->
    <section data-talleres-section="taller_deportivo" class="hidden py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Taller Deportivo</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Programas deportivos que forjan el carácter, la disciplina y el trabajo en equipo, promoviendo hábitos de vida saludable y el espíritu competitivo en nuestros estudiantes.
          </p>
        </div>
        <div class="space-y-24">

          <!-- Ajedrez -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/ajedrez.jpg" alt="Taller de Ajedrez"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1529699211952-734e80c4d42b?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">OPTATIVO</span>
              <h3 class="text-4xl font-bold text-colegio-blue">♟️Ajedrez</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Espacio formativo donde los estudiantes desarrollan habilidades de análisis, estrategia y resolución de problemas a través del ajedrez.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Grupo 1: 4° a 6° de Primaria</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Grupo 2: Nivel Secundaria</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Fútbol -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">SELECCIÓN</span>
              <h3 class="text-4xl font-bold text-colegio-blue">⚽Fútbol</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Equipo masculino que fortalece el trabajo en equipo, la disciplina y la práctica deportiva en competencias escolares.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Nivel Secundaria – Varones</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Categoría C</span>
                </li>
              </ul>
            </div>
            <div>
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/voleibol.jpg" alt="Taller de Vóley"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1579952363873-27f3bade9f55?auto=format&fit=crop&q=80&w=800'" />
              </div>
            </div>
          </div>

          <!-- Vóley -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="order-2 md:order-1">
              <div class="rounded-2xl overflow-hidden shadow-2xl group">
                <img src="/Talleres/futbol.jpg" alt="Taller de Fútbol"
                  class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.src='https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?auto=format&fit=crop&q=80&w=800'" />
                  
              </div>
            </div>
            <div class="order-1 md:order-2 space-y-4">
              <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">SELECCIÓN</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🏐Vóley</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Equipo femenino que desarrolla habilidades deportivas, coordinación y trabajo en equipo en competencias institucionales.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Nivel Secundaria – Damas</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <span class="text-gray-700">Categoría B</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Futsal -->
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="space-y-4">
              <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">SELECCIÓN</span>
              <h3 class="text-4xl font-bold text-colegio-blue">🏃‍♂️Futsal</h3>
              <p class="text-gray-700 text-lg leading-relaxed">
                Equipo deportivo que promueve la técnica, la agilidad y el trabajo colectivo en torneos y actividades deportivas.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
