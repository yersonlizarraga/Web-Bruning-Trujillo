<style>
  /* Animaciones suaves para las imágenes */
  img {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  [data-logros-section] {
    transition: opacity 0.25s ease;
  }
</style>

<script>
  const botones = document.querySelectorAll('.logros-btn');
  const secciones = document.querySelectorAll('[data-logros-section]');

  function mostrarSeccion(seccion: string) {
    secciones.forEach(s => {
      const el = s as HTMLElement;
      if (el.dataset.logrosSection === seccion) {
        el.classList.remove('hidden');
        el.style.opacity = '0';
        requestAnimationFrame(() => { el.style.opacity = '1'; });
      } else {
        el.classList.add('hidden');
      }
    });
  }

  botones.forEach(btn => {
    btn.addEventListener('click', () => {
      botones.forEach(b => {
        b.classList.remove('active', 'bg-colegio-yellow');
        b.classList.add('bg-white');
      });
      btn.classList.add('active', 'bg-colegio-yellow');
      btn.classList.remove('bg-white');
      const sec = (btn as HTMLElement).dataset.seccion;
      if (sec) mostrarSeccion(sec);
    });
  });

  // Mostrar académicos por defecto
  mostrarSeccion('2025');
</script>
