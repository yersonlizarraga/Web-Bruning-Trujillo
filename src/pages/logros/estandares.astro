---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Logros | BRÜNING SCHOOL" description="Conoce los logros académicos, deportivos y empresariales de los alumnos de Brüning School. Orgullo de Trujillo y del Perú.">
  <main class="pt-24 md:pt-20">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-colegio-blue via-colegio-blue/90 to-colegio-blue text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
          Nuestros <span class="text-colegio-yellow">Estándares internacionales</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto">
          El fruto de la excelencia educativa y el compromiso de nuestra comunidad
        </p>
      </div>
    </section>

    <!-- Filtros de categoría -->
    <section class="py-10 bg-white sticky top-16 z-40 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-3">
        <button class="logros-btn active bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2025">⭐ 2025</button>
        <button class="logros-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2026">⭐ 2026</button>
        <!--<button class="logros-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2027">⭐ Estándares</button> -->
      </div>
    </section>

    <!-- 2025 -->
    <section data-logros-section="2025" class="hidden py-20 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-7xl mx-auto px-4">
        <!-- Introducción -->
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Estándares Académicos Internacionales</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Brindamos a nuestros estudiantes certificaciones de reconocimiento internacional que 
            avalan su dominio del idioma inglés y competencias digitales empresariales.
          </p>
        </div>

        <!-- Grid de Certificaciones -->
        <div class="space-y-24">
        
        <!-- Certificación Cambridge -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1">
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/cambridge.jpg" 
                alt="Certificación Internacional Cambridge"
                class="w-full h-[500px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1546410531-bb4caa6b424d?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
          <div class="order-1 md:order-2 space-y-6">
            <span class="inline-block bg-gradient-to-r from-blue-600 to-blue-800 text-white font-bold px-6 py-2 rounded-full text-sm shadow-lg">
              CERTIFICACIÓN INTERNACIONAL
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">CERTIFICACIONES Internacional de Inglés - Cambridge</h3>

            <div class="bg-gradient-to-br from-colegio-blue to-blue-900 rounded-2xl p-8 text-white text-center shadow-2xl">
              <div class="text-6xl font-extrabold mb-2 text-colegio-yellow">200+</div>
              <p class="text-xl font-semibold">
                de estudiantes con certificación CAMBRIDGE
              </p>
            </div>

            <p class="text-gray-700 text-lg leading-relaxed">
              Convenio interinstitucional con la Universidad César Vallejo que garantiza certificaciones 
              reconocidas mundialmente, preparando a nuestros estudiantes desde 1° de secundaria.
            </p>
            
            <!-- Niveles de Certificación -->
            <div class="bg-gradient-to-br from-blue-50 to-white rounded-2xl p-6 border-2 border-colegio-blue/20">
              <h4 class="font-bold text-xl text-colegio-blue mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-colegio-yellow" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
                  <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
                </svg>
                Niveles de Certificación:
              </h4>
              <div class="space-y-3">
                <div class="flex items-center gap-3 p-3 bg-white rounded-lg border-l-4 border-green-500">
                  <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-white font-bold">A1</span>
                  </div>
                  <div>
                    <p class="font-bold text-gray-800">Movers (A1)</p>
                    <p class="text-sm text-gray-600">Nivel elemental</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 p-3 bg-white rounded-lg border-l-4 border-blue-500">
                  <div class="w-12 h-12 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-white font-bold">A2</span>
                  </div>
                  <div>
                    <p class="font-bold text-gray-800">KET (A2)</p>
                    <p class="text-sm text-gray-600">Key English Test</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 p-3 bg-white rounded-lg border-l-4 border-colegio-blue">
                  <div class="w-12 h-12 bg-colegio-blue rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-white font-bold">B1</span>
                  </div>
                  <div>
                    <p class="font-bold text-gray-800">PET (B1)</p>
                    <p class="text-sm text-gray-600">Preliminary English Test</p>
                  </div>
                </div>
              </div>
            </div>

            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Convenio con Universidad César Vallejo (UCV)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Preparación desde 1° de secundaria</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Charlas de concientización a padres y estudiantes</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Certificación de reconocimiento mundial</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Certificación IBEC -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="space-y-6">
            <span class="inline-block bg-gradient-to-r from-colegio-yellow to-yellow-500 text-colegio-blue font-bold px-6 py-2 rounded-full text-sm shadow-lg">
              CERTIFICACIÓN DIGITAL Y EMPRESARIAL
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">CertiFIcación en Competencias Digitales y Empresariales – IBEC</h3>
            
            <!-- Estadística Destacada -->
            <div class="bg-gradient-to-br from-colegio-blue to-blue-900 rounded-2xl p-8 text-white text-center shadow-2xl">
              <div class="text-6xl font-extrabold mb-2 text-colegio-yellow">70+</div>
              <p class="text-xl font-semibold">
                de estudiantes con certificación IBEC
              </p>
            </div>

            <p class="text-gray-700 text-lg leading-relaxed">
              Preparamos a nuestros estudiantes en competencias digitales y empresariales esenciales 
              para el mundo profesional del siglo XXI, con certificaciones internacionales IBEC.
            </p>
            
            <!-- Certificaciones IBEC -->
            <div class="bg-gradient-to-br from-yellow-50 to-white rounded-2xl p-6 border-2 border-colegio-yellow/30">
              <h4 class="font-bold text-xl text-colegio-blue mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-colegio-yellow" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd"/>
