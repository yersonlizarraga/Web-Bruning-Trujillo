---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Logros | BRÜNING SCHOOL" description="Conoce los logros académicos, deportivos y empresariales de los alumnos de Brüning School. Orgullo de Trujillo y del Perú.">
  <main class="pt-24 md:pt-20">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-colegio-blue via-colegio-blue/90 to-colegio-blue text-white py-20">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6">
          Nuestros <span class="text-colegio-yellow">Logros Académicos</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto">
          El fruto de la excelencia educativa y el compromiso de nuestra comunidad
        </p>
      </div>
    </section>

    <!-- Filtros de categoría -->
    <section class="py-10 bg-white sticky top-16 z-40 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-3">
        <button class="logros-btn active bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2025">🎓2025</button>
        <button class="logros-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2026">🎓2026</button>
        <!--<button class="logros-btn bg-white border-2 border-colegio-blue/20 hover:bg-colegio-yellow text-colegio-blue font-bold py-3 px-6 rounded-full shadow-lg transition-all duration-300 transform hover:scale-105" data-seccion="2027">🎓2027</button> -->
      </div>
    </section>

    <!-- 2025 -->
  <section data-logros-section="2025">

  <!-- ===================== -->
  <!-- BLOQUE AZUL -->
  <!-- ===================== -->
  <div class="py-20 bg-white">

        <div class="max-w-7xl mx-auto px-4">
        <!-- Introducción -->
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-colegio-blue mb-3">Logros Académicos</h2>
          <div class="w-24 h-1 bg-colegio-yellow mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Nuestros estudiantes destacan constantemente en concursos y olimpiadas a nivel nacional, 
            demostrando la calidad de su formación académica y el compromiso con la excelencia.
          </p>
        </div>

        <!-- Grid de Logros -->
        <div class="space-y-24">
        
        <!-- Rally Nacional de Matemática – GENIUS -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1">
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/genius.jpg" 
                alt="Rally Nacional de Matemática - GENIUS"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1509228468518-180dd4864904?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
          <div class="order-1 md:order-2 space-y-4">
            <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">
              MATEMÁTICA
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">Rally Nacional de Matemática – GENIUS</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Participación destacada de nuestros estudiantes en uno de los concursos de matemática más 
              prestigiosos del país, demostrando habilidades excepcionales en razonamiento lógico y resolución de problemas.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Competencia nacional de alto nivel</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Múltiples finalistas y ganadores</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Reconocimiento nacional a la excelencia académica</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Rally Nacional de Matemática – NOR PERÚ -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="space-y-4">
            <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">
              MATEMÁTICA
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">Rally Nacional de Matemática – NOR PERÚ</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Excelente desempeño en el Rally NOR PERÚ, consolidando nuestro compromiso con la formación 
              matemática de excelencia y el desarrollo del pensamiento analítico de nuestros estudiantes.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Participación activa en todas las categorías</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Medallas y reconocimientos obtenidos</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Representación destacada del norte del país</span>
              </li>
            </ul>
          </div>
          <div>
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/norperu.jpg" 
                alt="Rally Nacional de Matemática - NOR PERÚ"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1596496181848-3091d4878b24?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
        </div>

        <!-- ONEM – Olimpiada Nacional Escolar de Matemática -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1">
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/onem.jpg" 
                alt="ONEM - Olimpiada Nacional Escolar de Matemática"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
          <div class="order-1 md:order-2 space-y-4">
            <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">
              MINEDU
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">ONEM – Olimpiada Nacional Escolar de Matemática</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Participación destacada en la Olimpiada Nacional organizada por el Ministerio de Educación, 
              donde nuestros estudiantes representan con orgullo a nuestra institución y región.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Olimpiada oficial del MINEDU</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Clasificados a etapas regionales y nacionales</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Medallas y reconocimientos del Estado Peruano</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Olimpiada Provincial de Letras y Humanidades Marshall -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="space-y-4">
            <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">
              LETRAS Y HUMANIDADES
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">Olimpiada Provincial de Letras y Humanidades Marshall</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Excelente desempeño en competencias de comunicación, literatura y ciencias sociales, 
              demostrando una formación integral y multidisciplinaria de nuestros estudiantes.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Competencia en múltiples disciplinas humanísticas</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Primeros lugares en diversas categorías</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Formación integral en humanidades</span>
              </li>
            </ul>
          </div>
          <div>
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/marshall.jpg" 
                alt="Olimpiada Provincial de Letras - Marshall"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
        </div>

        <!-- Olimpiada Provincial de Matemáticas Fibonacci -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="order-2 md:order-1">
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/fibonacci.jpg" 
                alt="Olimpiada Provincial de Matemáticas Fibonacci"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1516414447565-b14be0adf13e?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
          <div class="order-1 md:order-2 space-y-4">
            <span class="inline-block bg-colegio-yellow text-colegio-blue font-bold px-4 py-2 rounded-full text-sm">
              MATEMÁTICA
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">Olimpiada Provincial de Matemáticas Fibonacci</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Destacada participación en la Olimpiada Fibonacci, donde nuestros estudiantes demuestran 
              su pasión por las matemáticas y habilidades en resolución de problemas complejos.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Competencia de prestigio provincial</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Múltiples medallas y distinciones</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Excelencia en razonamiento matemático</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- COREFOMATH – Concurso Nacional de Matemática -->
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div class="space-y-4">
            <span class="inline-block bg-colegio-blue text-white font-bold px-4 py-2 rounded-full text-sm">
              MATEMÁTICA
            </span>
            <h3 class="text-4xl font-bold text-colegio-blue">COREFOMATH – Concurso Nacional de Matemática</h3>
            <p class="text-gray-700 text-lg leading-relaxed">
              Participación sobresaliente en COREFOMATH, consolidando nuestra reputación como institución 
              comprometida con la excelencia en la formación matemática de nuestros estudiantes.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Concurso nacional de alto nivel competitivo</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Resultados destacados año tras año</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-colegio-yellow flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-700">Preparación rigurosa y especializada</span>
              </li>
            </ul>
          </div>
          <div>
            <div class="rounded-2xl overflow-hidden shadow-2xl group">
              <img 
                src="/Logros/corefomath.jpg" 
                alt="COREFOMATH - Concurso Nacional de Matemática"
                class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-500"
                onerror="this.src='https://images.unsplash.com/photo-1587825140708-dfaf72ae4b04?auto=format&fit=crop&q=80&w=800'"
              />
            </div>
          </div>
        </div>

      </div>
      </div>

  </div>


  <!-- ===================== -->
  <!-- BLOQUE BLANCO -->
  <!-- ===================== -->


  <div class="bg-colegio-blue py-20 text-white">
    <div class="max-w-7xl mx-auto px-4">

      <div class="text-center mb-16">
        <div class="w-24 h-24 bg-colegio-yellow rounded-full flex items-center justify-center mx-auto mb-8">
          <svg class="w-12 h-12 text-colegio-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
          </svg>
        </div>

        <h2 class="text-5xl font-extrabold mb-6">
          Ingresantes a Universidades
        </h2>

        <div class="w-32 h-1 bg-colegio-yellow mx-auto mb-6"></div>

        <p class="text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Nuestros egresados continúan su formación en las mejores universidades del país
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-8 mb-12">

        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border-2 border-white/20 text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-extrabold text-colegio-blue">UNT</span>
          </div>
          <h4 class="font-bold text-lg mb-2">Universidad Nacional de Trujillo</h4>
          <p class="text-colegio-yellow font-semibold text-sm">Nacional</p>
        </div>

        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border-2 border-white/20 text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-extrabold text-colegio-blue">UPAO</span>
          </div>
          <h4 class="font-bold text-lg mb-2">Universidad Privada Antenor Orrego</h4>
          <p class="text-colegio-yellow font-semibold text-sm">Privada</p>
        </div>

        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border-2 border-white/20 text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-extrabold text-colegio-blue">UTP</span>
          </div>
          <h4 class="font-bold text-lg mb-2">Universidad Tecnológica del Perú</h4>
          <p class="text-colegio-yellow font-semibold text-sm">Privada</p>
        </div>

        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border-2 border-white/20 text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-extrabold text-colegio-blue">UPN</span>
          </div>
          <h4 class="font-bold text-lg mb-2">Universidad Privada del Norte</h4>
          <p class="text-colegio-yellow font-semibold text-sm">Privada</p>
        </div>

        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border-2 border-white/20 text-center">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-4">
